{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "../unwantedFiles/projectLinkIconsList copy.tsx",
    "../unwantedFiles/myProjects copy.ts",
    "../portfolio favicon/projects with catagoreis Done/projectCatagorySection.tsx",
    "src/components/layouts/projectsNavBar.tsx",
    "../portfolio favicon/projects with catagoreis Done/portfolioLinkContentsData.ts"
  ],
  "exclude": ["node_modules"]
}
